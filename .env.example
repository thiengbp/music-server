# Port to expose on the host machine
PORT=3000

# Path to your music library on the host machine
# For local testing, you can use ./music
# For actual server deployments (like LXC), change this to /opt/music-server/music
HOST_MUSIC_PATH=./music

# Database path inside the container (keep default for persistence)
DATABASE_PATH=/app/data/music.db

# Auto scan interval in minutes
LIBRARY_SCAN_INTERVAL_MINUTES=15
